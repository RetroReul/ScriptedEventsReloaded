func ExplodeAll
    Explode *
end

run ExplodeAll  # this just explodes everyone


func @SigmasOnly
    return RemovePlayers * @classDPlayers
end

@sigmas = run @SigmasOnly
Explode @sigmas  # after this, only class d players will be alive


func $Add with $a $b
    return $a + $b
end

$sum = run $Add 5 3  # $a will be 5, $b will be 3
Print $sum  # prints 8
